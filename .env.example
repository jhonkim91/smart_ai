# ── Discord ──────────────────────────────────────────────
# Developer Portal (https://discord.com/developers/applications)에서 발급
DISCORD_BOT_TOKEN=
# 서버(길드) ID — Discord 설정 > 고급 > 개발자 모드 켠 뒤 서버 우클릭 > ID 복사
DISCORD_GUILD_ID=
# 승인 카드가 게시될 채널 ID
DISCORD_APPROVAL_CHANNEL_ID=
# 일반 로그/알림 채널 ID
DISCORD_LOG_CHANNEL_ID=
# 채널 설정 > 연동 > 웹후크에서 생성 (notify.py / n8n 공용)
DISCORD_WEBHOOK_URL=

# ── Ollama (로컬 무료 LLM) ───────────────────────────────
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_EMBED_MODEL=nomic-embed-text

# ── 트렌드 수집 ──────────────────────────────────────────
# 쉼표로 구분된 RSS 피드 URL 목록
# 예: https://news.google.com/rss?hl=ko&gl=KR&ceid=KR:ko,https://rss.etnews.com/Section901.xml
TREND_RSS_FEEDS=

# YouTube Data API v3 키 (videos.list chart=mostPopular 전용, 선택)
# GCP Console > API & Services > Credentials에서 API Key 생성
# 1일 할당량: 10,000 units, videos.list 1회 = 1 unit
YOUTUBE_API_KEY=

# ── 경로 ─────────────────────────────────────────────────
# Obsidian vault 경로. 기존 vault를 쓰려면 절대경로로 교체
VAULT_PATH=./vault
DATA_DIR=./data
