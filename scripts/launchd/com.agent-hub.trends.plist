<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
    "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.agent-hub.trends</string>

    <!-- install_launchd.sh 실행 시 __PROJECT_DIR__이 절대 경로로 치환된다 -->
    <key>ProgramArguments</key>
    <array>
        <string>__PROJECT_DIR__/.venv/bin/python</string>
        <string>-m</string>
        <string>pipelines.shorts.trends</string>
    </array>

    <key>WorkingDirectory</key>
    <string>__PROJECT_DIR__</string>

    <!-- 매일 09:00 KST (시스템 시간대가 KST로 설정되어 있어야 함) -->
    <key>StartCalendarInterval</key>
    <dict>
        <key>Hour</key>
        <integer>9</integer>
        <key>Minute</key>
        <integer>0</integer>
    </dict>

    <key>StandardOutPath</key>
    <string>__PROJECT_DIR__/data/logs/trends.log</string>

    <key>StandardErrorPath</key>
    <string>__PROJECT_DIR__/data/logs/trends.log</string>

    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
    </dict>

    <!-- 로그인 시 즉시 실행하지 않음; 09:00 스케줄만 따른다 -->
    <key>RunAtLoad</key>
    <false/>
</dict>
</plist>
